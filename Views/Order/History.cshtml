@model List<KarisBrook.Models.Order>

@{
    ViewData["Title"] = "История заказов";
}

<div class="container">
    <h2>История заказов</h2>

    @if (!Model.Any())
    {
        <p>У вас ещё нет заказов.</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>№</th>
                    <th>Дата</th>
                    <th>Сумма</th>
                    <th>Статус</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td>@order.Id</td>
                        <td>@order.OrderDate.ToString("dd.MM.yyyy")</td>
                        <td>@order.TotalPrice ₽</td>
                        <td>@order.Status</td>
                        <td>
                            <a href="@Url.Action("Success", new { id = order.Id })" class="btn btn-sm btn-primary">Детали</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>