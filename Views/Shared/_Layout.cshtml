                                            <li><a href="/Products/List?brand=Arthur Ashe">Arthur Ashe</a></li>
                                            <li><a href="/Products/List?brand=Brawl Stars">Brawl Stars</a></li>
                                            <li><a href="/Products/List?brand=Artemis">Artemis</a></li>
                                            <li><a href="/Products/List?brand=D. Molina">D. Molina</a></li>
                                            <li><a href="/Products/List?brand=Construe">Construe</a></li>
                                            <li><a href="/Products/List?brand=Hood">Hood</a></li>
                                            <li><a href="/Products/List?brand=Strellson">Strellson</a></li>
                                            <li><a href="/Products/List?brand=Lindbergh">Lindbergh</a></li>
                                            <li><a href="/Products/List?brand=Gant">Gant</a></li>
                                            <li><a href="/Products/List?brand=Boast">Boast</a></li>
                                            <li><a href="/Products/List?brand=Tintin">Tintin</a></li>
                                        </ul>
                                    </li>
                                    <li>
                                        <a href="/Products/List">Разное</a>
                                        <ul>
                                            <li><a href="/Products/List?category=gifts">Подарки</a></li>
                                            <li><a href="/Products/List?category=household goods">Товары для дома</a></li>
                                            <li><a href="/Products/List?category=combs">Расчёски</a></li>
                                            <li><a href="/Products/List?category=parfum">Духи</a></li>
                                            <li><a href="/Products/List?category=tea">Чай</a></li>
                                            <li><a href="/Products/List?category=face masks">Маски для лица</a></li>
                                            <li><a href="/Products/List?category=care-products">Уход</a></li>
                                            <li><a href="/Products/List?category=other">Другое</a></li>
                                        </ul>
                                    </li>
                                    <li><a href="/Sales">Распродажи</a></li>
                                    <li><a href="/Favourites">Избранное</a></li>
                                    <li><a href="/Collections">Коллекции</a></li>
                                    <li><a href="/Random">Рандом</a></li>
                                </ul>
                            </nav>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- END MAIN-MENU-AREA -->
        <!-- Start Mobile-menu -->
        <div class="mobile-menu-area hidden-md hidden-lg">
            <div class="container">
                <div class="row">
                    <div class="col-xs-12">
                        <nav id="mobile-menu">
                            <ul>
                                <!-- Аналогично основному меню, но в сокращенном виде -->
                                <li><a href="/New">Новинки</a></li>
                                <li>
                                    <a href="/Products/List">Одежда</a>
                                    <ul>
                                        <li><a href="/Products/List?category=polo">Поло</a></li>
                                        <li><a href="/Products/List?category=sweater">Свитера</a></li>
                                        <!-- и так далее -->
                                    </ul>
                                </li>
                                <!-- Остальные пункты меню... -->
                            </ul>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
        <!-- End Mobile-menu -->
    </header>
    <!-- HEADER AREA END -->
    <!-- START MAIN CONTENT -->
    @RenderBody()
    <!-- END MAIN CONTENT -->
    <!-- FOOTER-AREA START -->
    <footer class="footer-area">
        <div class="footer">
            <div class="container">
                <div class="row">
                    <div class="col-md-3 col-sm-4 col-xs-12">
                        <div class="logo">
                            <a href="/" title="KarisBrook"><img src="~/logo/logo2.png" alt="KarisBrook"></a>
                        </div>
                    </div>
                    <div class="col-md-5 col-sm-4 col-xs-12">
                        <label class="hidden-sm hidden-xs">Подпишитесь на нашу рассылку:</label>
                        <div class="subscribe">
                            <form action="#">
                                <input type="text" placeholder="Enter Your E-mail">
                                <button type="submit">Подпешись</button>
                            </form>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-4 col-xs-12">
                        <label class="hidden-sm hidden-xs">Оставайтесь на связи:</label>
                        <div class="social-media">
                            <a href="#"><i class="fa fa-facebook fb"></i></a>
                            <a href="#"><i class="fa fa-google-plus gp"></i></a>
                            <a href="#"><i class="fa fa-twitter tt"></i></a>
                            <a href="#"><i class="fa fa-youtube yt"></i></a>
                            <a href="#"><i class="fa fa-linkedin li"></i></a>
                            <a href="#"><i class="fa fa-rss rs"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </footer>
    <!-- FOOTER-AREA END -->
    <!-- SCRIPTS -->
    <script src="~/js/jquery-1.11.3.min.js"></script>
    <script src="~/js/bootstrap.min.js"></script>
    <script src="~/js/wow.min.js"></script>
    <script src="~/js/jquery.meanmenu.js"></script>
    <script src="~/js/owl.carousel.min.js"></script>
    <script src="~/js/jquery.scrollUp.min.js"></script>
    <script src="~/js/countdon.min.js"></script>
    <script src="~/js/jquery-price-slider.js"></script>
    <script src="~/js/jquery.nivo.slider.js" type="text/javascript"></script>
    <script src="~/js/imagezoom.js"></script>
    <script src="~/js/plugins.js"></script>
    <script src="~/js/main.js"></script>
    <script src="~/js/style-slider.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>