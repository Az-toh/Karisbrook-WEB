<!doctype html>
<html class="no-js" lang="">
<head>
    <meta charset="utf-8">
    <meta http-equiv="x-ua-compatible" content="ie=edge">
    <title>@ViewData["Title"] - KarisBrook</title>
    <meta name="description" content="">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link rel="shortcut icon" type="image/x-icon" href="~/img/favicon.ico">

    <!-- Google Fonts -->
    <link href='https://fonts.googleapis.com/css?family=Raleway:400,600' rel='stylesheet' type='text/css'>
    <link href='https://fonts.googleapis.com/css?family=Roboto:400,700' rel='stylesheet' type='text/css'>

    <!-- CSS -->
    <link rel="stylesheet" href="~/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/font-awesome.min.css">
    <link rel="stylesheet" href="~/css/owl.carousel.css">
    <link rel="stylesheet" href="~/css/owl.theme.css">
    <link rel="stylesheet" href="~/css/owl.transitions.css">
    <link rel="stylesheet" href="~/css/nivo-slider.css" type="text/css" />
    <link rel="stylesheet" href="~/css/meanmenu.min.css">
    <link rel="stylesheet" href="~/css/jquery-ui.css">
    <link rel="stylesheet" href="~/css/animate.css">
    <link rel="stylesheet" href="~/css/main.css">
    <link rel="stylesheet" href="~/css/style.css">
    <link rel="stylesheet" href="~/css/responsive.css">
    <link rel="stylesheet" href="~/css/style-slider.css">

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- HEADER-AREA START -->
    <header class="header-area">
        <!-- HEADER-TOP START -->
        <div class="header-top hidden-xs">
            <div class="container">
                <div class="row">
                    <div class="col-xs-12 col-sm-12 col-md-12 col-lg-12">
                        <div class="top-link">
                            <ul class="link">
                                <!-- Корзина -->
                                <li>
                                    <a href="/Cart"><i class="fa fa-shopping-cart"></i> Корзина </a>
                                    <!-- Мини-корзина (остается как есть, позже сделаем динамической) -->
                                </li>


                                <!-- Аутентификация -->
                                @if (User.Identity.IsAuthenticated)
                                {
                                   
                                        <!-- ИСТОРИЯ ЗАКАЗОВ (ДОБАВЛЕНА) -->
                                        <li>
                                            <a href="@Url.Action("History", "Order")">
                                                <i class="fa fa-history"></i> История заказов
                                            </a>
                                        </li>
                                    <li><a href="/Account/Profile"><i class="fa fa-user"></i> @User.Identity.Name </a></li>
                                    <li>
                                        <form asp-action="Logout" asp-controller="Account" method="post" style="display:inline;">
                                            <button type="submit" class="btn btn-link" style="padding:0; color:inherit; border:none; background:none;">
                                                <i class="fa fa-sign-out"></i> Выход
                                            </button>
                                        </form>
                                    </li>
                                }
                                else
                                {
                                    <li><a href="/Account/Login"><i class="fa fa-user"></i> Вход</a></li>
                                    <li><a href="/Account/Register"><i class="fa fa-unlock-alt"></i> Регистрация</a></li>
                                }

                                <!-- Прочие ссылки (пока статические) -->
                                <li><a href="/Wishlist"><i class="fa fa-heart"></i> Вишлист </a></li>
                                <li><a href="/Compare"><i class="fa fa-signal"></i> Сравнение </a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- HEADER-TOP END -->
        <!-- HEADER-MIDDLE START -->
        <div class="header-middle">
            <div class="container">
                <div class="row">
                    <div class="col-md-3 col-sm-4 col-xs-12">
                        <div class="logo">
                            <a href="/" title="KarisBrook"><img src="~/logo/logo1.png" alt="KarisBrook"></a>
                        </div>
                    </div>
                    <div class="col-md-6 col-sm-5 col-xs-12">
                        <div class="quick-access">
                            <div class="search-by-category">
                                <div class="header-search">
                                    <form action="#">
                                        <input type="text" placeholder="Search">
                                        <button type="submit"><i class="fa fa-search"></i></button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-3 col-xs-12">
                        <div class="header-menu">
                            <nav>
                                <ul>
                                    <li><a href="/Blog">Блог</a>
                                    <li><a href="/About">О нас</a>
                                </ul>
                            </nav>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- HEADER-MIDDLE END -->
        <!-- START MAINMENU-AREA -->
