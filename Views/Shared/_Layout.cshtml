                                            <li><a href="/Products/List?category=moccasins">Мокасины</a></li>
                                            <li><a href="/Products/List?category=sneakers">Кроссовки</a></li>
                                            <li><a href="/Products/List?category=slippers">Тапочки</a></li>
                                            <li><a href="/Products/List?category=slates">Сланцы</a></li>
                                            <li><a href="/Products/List?category=ballet flats">Балетки</a></li>
                                            <li><a href="/Products/List?category=sandals">Босоножки</a></li>
                                        </ul>
